@baseUrl = http://localhost:3000/api
@employeeId = REPLACE_WITH_UUID
@storeId = REPLACE_WITH_UUID
@inventoryId = REPLACE_WITH_UUID
@attendanceId = REPLACE_WITH_UUID

### Health checks

GET {{baseUrl}}/health

###

GET {{baseUrl}}/health/database

### Autenticación

# Login administrador
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@dinamicsystems.com",
  "password": "cambiar-esta-clave"
}

###

@authToken = REPLACE_WITH_JWT

# Usuario autenticado actual
GET {{baseUrl}}/auth/me
Authorization: Bearer {{authToken}}

### Empleados

# Crear empleado
POST {{baseUrl}}/employees
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "name": "Juan Perez",
  "documentNumber": "30111222",
  "phoneNumber": "+5491112345678"
}

###

# Listar empleados (paginación y filtros)
GET {{baseUrl}}/employees?page=1&limit=20&active=true&search=Juan

###

# Obtener empleado por ID
GET {{baseUrl}}/employees/{{employeeId}}

###

# Actualizar empleado
PUT {{baseUrl}}/employees/{{employeeId}}
Content-Type: application/json

{
  "name": "Juan Perez Actualizado",
  "documentNumber": "30111222",
  "phoneNumber": "+5491112345678",
  "active": true
}

###

# Desactivar empleado (baja lógica)
DELETE {{baseUrl}}/employees/{{employeeId}}

###

# Ejemplo inválido: teléfono duplicado (esperado 409)
# POST {{baseUrl}}/employees
# Content-Type: application/json
#
# {
#   "name": "Otro Empleado",
#   "phoneNumber": "+5491112345678"
# }

###

# Ejemplo inválido: UUID inválido (esperado 400)
# GET {{baseUrl}}/employees/not-a-uuid

###

# Ejemplo inválido: desactivar empleado con inventario SCHEDULED/IN_PROGRESS (esperado 409)
# DELETE {{baseUrl}}/employees/{{employeeId}}

### Tiendas

POST {{baseUrl}}/stores
Content-Type: application/json

{
  "name": "Tienda Centro",
  "address": "Av. Corrientes 1234",
  "latitude": -34.6037,
  "longitude": -58.3816,
  "allowedRadiusMeters": 150
}

###

GET {{baseUrl}}/stores?page=1&limit=20&active=true&search=Centro

###

GET {{baseUrl}}/stores/{{storeId}}

###

PUT {{baseUrl}}/stores/{{storeId}}
Content-Type: application/json

{
  "name": "Tienda Centro Actualizada",
  "address": "Av. Corrientes 1234",
  "latitude": -34.6037,
  "longitude": -58.3816,
  "allowedRadiusMeters": 200,
  "active": true
}

###

DELETE {{baseUrl}}/stores/{{storeId}}

###

# Ejemplo inválido: latitud fuera de rango (esperado 400)
# POST {{baseUrl}}/stores
# Content-Type: application/json
#
# {
#   "name": "Tienda Inválida",
#   "latitude": 95,
#   "longitude": -58.3816,
#   "allowedRadiusMeters": 150
# }

###

# Ejemplo inválido: radio no positivo (esperado 400)
# POST {{baseUrl}}/stores
# Content-Type: application/json
#
# {
#   "name": "Tienda Inválida",
#   "latitude": -34.6037,
#   "longitude": -58.3816,
#   "allowedRadiusMeters": 0
