{
  "name": "dinamic-attendance",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo base para Dinamic Attendance.",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "npm --prefix backend run build",
    "build:frontend": "npm --prefix frontend run build",
    "migrate": "npm run migrate --prefix backend",
    "migrate:status": "npm run migrate:status --prefix backend",
    "admin:create": "npm run admin:create --prefix backend",
    "lint": "npm run lint --prefix frontend",
    "test": "npm run test --prefix backend && npm run test --prefix frontend",
    "audit": "bash scripts/audit/run_full_audit.sh",
    "audit:strict": "AUDIT_STRICT=1 bash scripts/audit/run_full_audit.sh && python3 scripts/audit/enforce_quality_gate.py --strict",
    "audit:summary": "python3 scripts/audit/generate_audit_summary.py",
    "audit:baseline": "python3 scripts/audit/save_baseline.py",
    "audit:security:fast": "bash scripts/audit/run_security_audit.sh",
    "audit:security:deep": "bash scripts/audit/run_security_audit_deep.sh"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
