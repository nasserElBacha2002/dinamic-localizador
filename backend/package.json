{
  "name": "dinamic-attendance-backend",
  "version": "0.1.0",
  "private": true,
  "description": "API base de Dinamic Attendance.",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate": "tsx src/database/run-migrations.ts",
    "migrate:status": "tsx src/database/run-migrations.ts --status",
    "admin:create": "tsx src/scripts/create-admin.ts",
    "seed:stores": "tsx src/scripts/seed-stores.ts",
    "seed:employees": "tsx src/scripts/seed-employees.ts",
    "reconcile:stores": "tsx src/scripts/reconcile-stores.ts",
    "export:stores": "tsx src/scripts/export-database-stores.ts",
    "fix:stores": "tsx src/scripts/fix-stores-from-reconciliation.ts",
    "twilio:signature:verify": "tsx src/scripts/verify-twilio-signature.ts",
    "reminders:run": "tsx src/scripts/send-attendance-reminder.ts run",
    "reminders:test": "tsx src/scripts/send-attendance-reminder.ts test",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "mssql": "^12.1.0",
    "twilio": "^6.0.2",
    "xlsx": "npm:@e965/xlsx@0.20.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/mssql": "^12.3.0",
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
