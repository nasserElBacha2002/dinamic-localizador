### Inventarios

POST {{baseUrl}}/inventories
Content-Type: application/json

{
  "storeId": "{{storeId}}",
  "scheduledStart": "2026-07-01T10:00:00.000Z",
  "scheduledEnd": "2026-07-01T14:00:00.000Z",
  "earlyToleranceMinutes": 60,
  "lateToleranceMinutes": 90,
  "notes": "Inventario de prueba"
}

###

GET {{baseUrl}}/inventories?page=1&limit=20&status=SCHEDULED&storeId={{storeId}}

###

GET {{baseUrl}}/inventories/{{inventoryId}}

###

PUT {{baseUrl}}/inventories/{{inventoryId}}
Content-Type: application/json

{
  "status": "IN_PROGRESS"
}

###

DELETE {{baseUrl}}/inventories/{{inventoryId}}

###

# Ejemplo inválido: transición de estado no permitida (esperado 409)
# PUT {{baseUrl}}/inventories/{{inventoryId}}
# Content-Type: application/json
#
# {
#   "status": "COMPLETED"
# }

### Asignaciones

POST {{baseUrl}}/inventories/{{inventoryId}}/employees
Content-Type: application/json

{
  "employeeId": "{{employeeId}}"
}

###

GET {{baseUrl}}/inventories/{{inventoryId}}/employees

###

DELETE {{baseUrl}}/inventories/{{inventoryId}}/employees/{{employeeId}}

###

# Ejemplo inválido: asignación duplicada (esperado 409)
# POST {{baseUrl}}/inventories/{{inventoryId}}/employees
# Content-Type: application/json
#
# {
#   "employeeId": "{{employeeId}}"
# }

###

# Ejemplo inválido: desasignar con asistencia registrada (esperado 409)
# DELETE {{baseUrl}}/inventories/{{inventoryId}}/employees/{{employeeId}}

### Asistencias

# Endpoint temporal de desarrollo — no es check-in productivo de WhatsApp/Twilio.
POST {{baseUrl}}/attendance
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "inventoryId": "{{inventoryId}}",
  "employeeId": "{{employeeId}}",
  "receivedLatitude": -34.6037,
  "receivedLongitude": -58.3816,
  "distanceMeters": 42.5,
  "validationStatus": "VALID",
  "locationStatus": "INSIDE_GEOFENCE",
  "punctualityStatus": "ON_TIME",
  "receivedAt": "2026-07-01T10:05:00.000Z",
  "sourceMessageSid": null,
  "validationReason": null
}

###

GET {{baseUrl}}/attendance?page=1&limit=20&validationStatus=VALID&storeId={{storeId}}
Authorization: Bearer {{authToken}}

###

GET {{baseUrl}}/attendance/{{attendanceId}}
Authorization: Bearer {{authToken}}

###

# Revisión manual de asistencia
PATCH {{baseUrl}}/attendance/{{attendanceId}}/review
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "decision": "APPROVE",
  "reason": "La tienda se encuentra dentro de un centro comercial y la señal GPS presentó desvío."
}

###

# Exportación CSV con filtros
GET {{baseUrl}}/attendance/export.csv?validationStatus=PENDING_REVIEW&dateFrom=2026-06-01T00:00:00.000Z
Authorization: Bearer {{authToken}}

###

# Resumen operativo de inventario
GET {{baseUrl}}/inventories/{{inventoryId}}/attendance-summary
Authorization: Bearer {{authToken}}

###

# Ejemplo inválido: empleado no asignado al inventario (esperado 409)
