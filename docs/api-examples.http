### WhatsApp / Twilio webhook

# Producción: TWILIO_VALIDATE_SIGNATURE=true
# La URL en Twilio Console debe coincidir exactamente con TWILIO_WEBHOOK_URL.
# Twilio envía application/x-www-form-urlencoded.
# La firma depende de URL pública + parámetros + TWILIO_AUTH_TOKEN (no API Key Secret).
# Tras cambiar .env en Docker, recrear el backend.
#
# Desarrollo local sin firma:
# TWILIO_VALIDATE_SIGNATURE=false en backend/.env
#
# Diagnóstico de firma (no imprime el token):
# TWILIO_AUTH_TOKEN=*** npm run twilio:signature:verify -- --url=URL --signature=SIG --params='k=v'

# Simula mensaje de texto "Llegué" (solo con TWILIO_VALIDATE_SIGNATURE=false)

POST {{baseUrl}}/webhooks/twilio/whatsapp
Content-Type: application/x-www-form-urlencoded

MessageSid=SM_TEST_001&From=whatsapp%3A%2B5491112345678&To=whatsapp%3A%2B14155238886&Body=Llegu%C3%A9

###

# Simula compartir ubicación (requiere sesión WAITING_LOCATION previa)

POST {{baseUrl}}/webhooks/twilio/whatsapp
Content-Type: application/x-www-form-urlencoded

MessageSid=SM_TEST_002&From=whatsapp%3A%2B5491112345678&To=whatsapp%3A%2B14155238886&Latitude=-34.5876&Longitude=-58.4102

###

# Ejemplo: número no registrado

POST {{baseUrl}}/webhooks/twilio/whatsapp
Content-Type: application/x-www-form-urlencoded

MessageSid=SM_TEST_UNKNOWN&From=whatsapp%3A%2B5491199999999&To=whatsapp%3A%2B14155238886&Body=Llegu%C3%A9

###

# Ejemplo: MessageSid duplicado (segunda llamada debe responder sin reprocesar)

POST {{baseUrl}}/webhooks/twilio/whatsapp
Content-Type: application/x-www-form-urlencoded

MessageSid=SM_TEST_DUP&From=whatsapp%3A%2B5491112345678&To=whatsapp%3A%2B14155238886&Body=Llegu%C3%A9

### Expiración de sesión (solo desarrollo)

# 1) Crear check-in y obtener sesión WAITING_LOCATION

POST {{baseUrl}}/webhooks/twilio/whatsapp
Content-Type: application/x-www-form-urlencoded

MessageSid=SM_EXP_001&From=whatsapp%3A%2B5491112345678&To=whatsapp%3A%2B14155238886&Body=Llegu%C3%A9

###

# 2) Forzar vencimiento en SQL Server (solo entorno local)
#
# Con Docker / sqlcmd usar QUOTED_IDENTIFIER ON (-I):
#
# docker exec dinamic-attendance-sqlserver /opt/mssql-tools18/bin/sqlcmd \
#   -S localhost -U sa -P "<password>" -C -I -d dinamic_attendance -Q "
# UPDATE bot_sessions
# SET expires_at = DATEADD(MINUTE, -1, SYSUTCDATETIME())
# WHERE phone_number = '+5491112345678'
#   AND state IN ('WAITING_LOCATION', 'WAITING_INVENTORY_SELECTION');"

###

# 3) Enviar ubicación después del vencimiento
# Resultado esperado:
# La solicitud anterior venció.
# Escribí "Llegué" para comenzar nuevamente.

POST {{baseUrl}}/webhooks/twilio/whatsapp
Content-Type: application/x-www-form-urlencoded

MessageSid=SM_EXP_002&From=whatsapp%3A%2B5491112345678&To=whatsapp%3A%2B14155238886&Latitude=-34.5876&Longitude=-58.4102

###

# 4) Reiniciar flujo con un nuevo "Llegué"

POST {{baseUrl}}/webhooks/twilio/whatsapp
Content-Type: application/x-www-form-urlencoded

MessageSid=SM_EXP_003&From=whatsapp%3A%2B5491112345678&To=whatsapp%3A%2B14155238886&Body=Llegu%C3%A9

