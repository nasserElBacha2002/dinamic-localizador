# Dinamic Attendance — variables de entorno para Docker Compose
#
# Copiá este archivo a `.env` en la raíz del proyecto y completá los valores.
# El `.env` raíz es la fuente de verdad para `docker compose` en el servidor.
#
# Para desarrollo local:
#   docker compose --env-file .env up -d --build
#
# Para producción:
#   docker compose --env-file .env -f docker-compose.yml -f docker-compose.prod.yml up -d --build
#
# `backend/.env` sirve para ejecutar Node fuera de Docker.
# `frontend/.env` sirve para Vite local (`npm run dev`).
# En producción Docker, las variables VITE_* se inyectan durante el build del frontend.

NODE_ENV=development
TZ=America/Argentina/Buenos_Aires

BACKEND_INTERNAL_PORT=3000
BACKEND_HOST_PORT=3000
FRONTEND_HOST_PORT=5173

FRONTEND_URL=http://localhost:5173
APP_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

VITE_API_URL=http://localhost:3000/api
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_MAP_ID=

DB_HOST=sqlserver
DB_PORT=1433
DB_PORT_EXTERNAL=14330
DB_NAME=dinamic_attendance
DB_USER=sa
DB_PASSWORD=
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
MSSQL_SA_PASSWORD=

JWT_SECRET=
JWT_EXPIRES_IN=8h

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
TWILIO_WEBHOOK_URL=
TWILIO_VALIDATE_SIGNATURE=false
TWILIO_ARRIVAL_REMINDER_CONTENT_SID=
TWILIO_EXIT_REMINDER_CONTENT_SID=
ATTENDANCE_REMINDER_JOB_ENABLED=true

BOT_SESSION_TTL_MINUTES=15
BOT_OPERATION_TIMEZONE=America/Argentina/Buenos_Aires
BOT_DEFAULT_RADIUS_METERS=150
BOT_GEOFENCE_REVIEW_MARGIN_METERS=30
BOT_ON_TIME_GRACE_MINUTES=15
