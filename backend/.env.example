# Variables para ejecutar el backend fuera de Docker (npm run dev en backend/).
# En producción con Docker Compose, usá el `.env` raíz del monorepo.

NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
APP_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
TZ=America/Argentina/Buenos_Aires

DB_HOST=localhost
DB_PORT=14330
DB_NAME=dinamic_attendance
DB_USER=sa
DB_PASSWORD=
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
TWILIO_WEBHOOK_URL=
# Debe coincidir exactamente con la URL pública configurada en Twilio (sin slash final).
TWILIO_VALIDATE_SIGNATURE=false
TWILIO_ARRIVAL_REMINDER_CONTENT_SID=
TWILIO_EXIT_REMINDER_CONTENT_SID=
TWILIO_ATTENDANCE_CONFIRMATION_CONTENT_SID=
TWILIO_TEMPLATE_NO_CHECKIN_SID=
ATTENDANCE_REMINDER_JOB_ENABLED=true
BOT_SESSION_TTL_MINUTES=15
# Fallbacks cuando no hay fila company_settings o valor explícito por empresa
BOT_OPERATION_TIMEZONE=America/Argentina/Buenos_Aires
BOT_DEFAULT_RADIUS_METERS=150
BOT_GEOFENCE_REVIEW_MARGIN_METERS=30
BOT_ON_TIME_GRACE_MINUTES=15
BOT_CHECKOUT_EARLY_TOLERANCE_MINUTES=15
# Opcional: empresa por defecto del bot cuando hay varias activas
# BOT_DEFAULT_COMPANY_ID=
# BOT_DEFAULT_COMPANY_NAME=Dinamic Systems

JWT_SECRET=
JWT_EXPIRES_IN=8h

# Ejecutar suites de integración con SQL Server local: RUN_DB_INTEGRATION_TESTS=true npm test
# RUN_DB_INTEGRATION_TESTS=true
